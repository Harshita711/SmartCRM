# Server
PORT=5000
NODE_ENV=development

# MongoDB
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/xeno-crm?retryWrites=true&w=majority

# Auth
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# Channel Service
CHANNEL_SERVICE_URL=http://localhost:6000
CHANNEL_SERVICE_API_KEY=shared_secret_between_services

# CRM public URL (used by channel service to send receipts back)
CRM_BASE_URL=http://localhost:5000

# Frontend
FRONTEND_URL=http://localhost:5173
