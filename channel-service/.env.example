# Server
PORT=6000
NODE_ENV=development

# MongoDB (separate collection for communication logs - can share the same cluster/db)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/xeno-channel-service?retryWrites=true&w=majority

# Shared secret - must match CHANNEL_SERVICE_API_KEY in the CRM backend .env
CHANNEL_SERVICE_API_KEY=shared_secret_between_services

# CRM backend base URL (for sending receipt callbacks)
CRM_BASE_URL=http://localhost:5000

# Simulation tuning
MIN_DELAY_MS=500
MAX_DELAY_MS=4000
FAILURE_RATE=0.1
MAX_RETRIES=3
